#!/usr/bin/env bash
INPUT_FILE=${1?Error: No input file given}
OUTPUT_FOLDER=${2?Error: No output folder given}
export INPUT_FILE
export OUTPUT_FOLDER

export OUT_FILE=../7_RESULTS/$OUTPUT_FOLDER/INCS_$OUTPUT_FOLDER.out
export ERR_FILE=../7_RESULTS/$OUTPUT_FOLDER/INCS_$OUTPUT_FOLDER.err
echo $OUT_FILE
echo $ERR_FILE

cd ../2_SOURCE_CODE/
rm ../3_COMPILED_FILES/INCS_Agis_*
make
cp ../3_COMPILED_FILES/INCS_Agis ../3_COMPILED_FILES/INCS_Agis_${OUTPUT_FOLDER}

#if [ -d ../7_RESULTS/$OUTPUT_FOLDER]; then
mkdir ../7_RESULTS/$OUTPUT_FOLDER
#	echo "Directory is created ..."
#fi

cd ../7_RESULTS/$OUTPUT_FOLDER/
find . -name '*GlobalLoc*' | xargs rm -f
mkdir 2_SOURCE_CODE

cd ../../2_SOURCE_CODE/
rm ../7_RESULTS/$OUTPUT_FOLDER/*
rm ../7_RESULTS/$OUTPUT_FOLDER/Bubbles/*
cp *.f90 ../7_RESULTS/$OUTPUT_FOLDER/2_SOURCE_CODE/
cp ../5_INPUT_FILES/$INPUT_FILE ../7_RESULTS/$OUTPUT_FOLDER/

cd ../6_RUN/
### HERE WE CREATE THE BASH FILE
echo "#!/bin/bash" > job_INCS_long
echo " " >> job_INCS_long
echo "#SBATCH --job-name=2_MONO_$OUTPUT_FOLDER" 		>> job_INCS_long
echo "#SBATCH --partition=imphys" 						>> job_INCS_long
