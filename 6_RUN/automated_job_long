echo "#SBATCH --ntasks-per-node=56" 					>> job_INCS_long
echo "#SBATCH --cpus-per-task=1"    					>> job_INCS_long
echo "#SBATCH --mem=500G"           					>> job_INCS_long
echo "#SBATCH --time=20:00:00"      					>> job_INCS_long
echo "#SBATCH --output=$OUT_FILE" 						>> job_INCS_long
echo "#SBATCH --error=$ERR_FILE"     					>> job_INCS_long
echo "##SBATCH --exclusive"          					>> job_INCS_long
echo " " 												>> job_INCS_long
echo "module use /opt/insy/modulefiles" 				>> job_INCS_long
echo "module load intel" 								>> job_INCS_long
echo " " 												>> job_INCS_long
echo "source /opt/insy/intel/2017u4/compilers_and_libraries_2017.4.196/linux/bin/compilervars.sh intel64" 		>> job_INCS_long
echo "source /opt/insy/intel/2017u4/compilers_and_libraries_2017.4.196/linux/mpi/bin64/mpivars.sh" 				>> job_INCS_long
echo "source /opt/insy/intel/2017u4/compilers_and_libraries_2017.4.196/linux/mkl/bin/mklvars.sh intel64" 		>> job_INCS_long
echo " " 												>> job_INCS_long
echo "ulimit -s unlimited" 								>> job_INCS_long
echo " " 												>> job_INCS_long
echo "# export I_MPI_PMI_LIBRARY=/home/opt/slurm/slurm-17.11.5/src/api/.libs/libpmi.so" 						>> job_INCS_long
echo "export I_MPI_PMI_LIBRARY=/usr/lib64/libpmi.so" 	>> job_INCS_long
echo "export OMP_NUM_THREADS=1" 						>> job_INCS_long
echo "export MKL_NUM_THREADS=1" 						>> job_INCS_long
echo "#export MKL_THREADING_LAYER=intel" 				>> job_INCS_long
echo "#export MKL_DYNAMIC="FALSE"" 						>> job_INCS_long
echo "#export MKL_VERBOSE=1" 							>> job_INCS_long
echo "srun ../3_COMPILED_FILES/INCS_Agis_${OUTPUT_FOLDER} $INPUT_FILE TESTNeumann ../5_INPUT_FILES ../7_RESULTS/$OUTPUT_FOLDER" >> job_INCS_long

sbatch ../6_RUN/job_INCS_long &

sleep 5
qstat -u agismatalliota
