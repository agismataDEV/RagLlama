srun ${INPUT_FOLDER}/7_RESULTS/${OUTPUT_FOLDER_DAVID}/INCS_Agis_${OUTPUT_FILE_NAME} ${INPUT_FILE_DAVID} TESTNeumann ../7_RESULTS/${OUTPUT_FOLDER_DAVID} ../7_RESULTS/${OUTPUT_FOLDER_DAVID}" > job_INCS_GG

