# sed "175s/.*/${val}/" ../5_INPUT_FILES/INCS_TEMP.in > ../5_INPUT_FILES/$INPUT_FILE_DAVID
# sed "193s/.*/${val}/" ../5_INPUT_FILES/$INPUT_FILE_DAVID > ../5_INPUT_FILES/INCS_TEMP.in
sed "61s/.*/${val_press}/" ../5_INPUT_FILES/$INPUT_FILE_DAVID > ../5_INPUT_FILES/INCS_TEMP.in  
sed "61s/.*/${val_press}/" ../5_INPUT_FILES/INCS_TEMP.in > ../5_INPUT_FILES/$INPUT_FILE_DAVID

cp ../5_INPUT_FILES/$INPUT_FILE_DAVID $INPUT_FOLDER/7_RESULTS/$OUTPUT_FOLDER_DAVID/
cp ../3_COMPILED_FILES/INCS_Agis_${OUTPUT_FILE_NAME} $INPUT_FOLDER/7_RESULTS/$OUTPUT_FOLDER_DAVID/

cd $INPUT_FOLDER/6_RUN/

### HERE WE CREATE THE BASH FILE
echo "#!/bin/bash  						 															
   											 															
#SBATCH --job-name=${OUTPUT_FOLDER_COMPOUND} 	 																
#SBATCH --partition=imphys,general  					 													
#SBATCH --qos=medium           				 															
#SBATCH --nodes=1-2           					 															
##SBATCH --constraint=ib  				 																
##SBATCH --network=IB  				 																	
#SBATCH --ntasks=100  		 																			
#SBATCH --cpus-per-task=1     				 															
