#!/usr/bin/env bash
INPUT_FILE_DAVID=${1?Error: No input file given}
OUTPUT_FOLDER_DAVID=${2?Error: No output folder given}
export INPUT_FILE_DAVID
export OUTPUT_FOLDER_DAVID
echo $INPUT_FILE_DAVID
echo $OUTPUT_FOLDER_DAVID

IFS=/ read OUTPUT_FOLDER_NAME OUTPUT_FILE_NAME <<< $OUTPUT_FOLDER_DAVID
echo $OUTPUT_FOLDER_NAME
echo $OUTPUT_FILE_NAME
echo $OUTPUT_FOLDER_DAVID
INPUT_FOLDER="//tudelft.net/staff-groups/tnw/ist/ak/Promovendi/agismatalliota/INCS_XWAVE"

A2="$(cut -d'_' -f2 <<<$OUTPUT_FILE_NAME)"
A3="$(cut -d '_' -f3 <<<$OUTPUT_FILE_NAME)"
A="${A2}_${A3}"

for press in {75..75..25} ; 
do

val_shift=$(echo " ${press}/25 -1" |bc)
# export OUTPUT_FOLDER_COMPOUND="5E4MBs_Positive_1_5MHz_${press}kPa_p${val_shift}_long"
export OUTPUT_FOLDER_COMPOUND="1E4MBs_Positive_1MHz_poly_${press}kPa_stronger"
export OUTPUT_FOLDER_DAVID=$OUTPUT_FOLDER_NAME/${OUTPUT_FOLDER_COMPOUND}

export OUT_FILE=$INPUT_FOLDER/7_RESULTS/$OUTPUT_FOLDER_DAVID/INCS_${OUTPUT_FILE_NAME}_${OUTPUT_FOLDER_COMPOUND}.out
export ERR_FILE=$INPUT_FOLDER/7_RESULTS/$OUTPUT_FOLDER_DAVID/INCS_${OUTPUT_FILE_NAME}_${OUTPUT_FOLDER_COMPOUND}.err

cd $INPUT_FOLDER/2_SOURCE_CODE/
make 
cp ../3_COMPILED_FILES/INCS_Agis ../3_COMPILED_FILES/INCS_Agis_${OUTPUT_FILE_NAME}

mkdir $INPUT_FOLDER/7_RESULTS/$OUTPUT_FOLDER_NAME
mkdir $INPUT_FOLDER/7_RESULTS/$OUTPUT_FOLDER_DAVID
mkdir $INPUT_FOLDER/7_RESULTS/$OUTPUT_FOLDER_DAVID/2_SOURCE_CODE/

rm $INPUT_FOLDER/7_RESULTS/$OUTPUT_FOLDER_DAVID/*
rm $INPUT_FOLDER/7_RESULTS/$OUTPUT_FOLDER_DAVID/Bubbles/*

cp ../2_SOURCE_CODE/*.f90 $INPUT_FOLDER/7_RESULTS/$OUTPUT_FOLDER_DAVID/2_SOURCE_CODE/

val=$(echo "scale=4; (${press}/25 -1)*0.05" |bc)
val_press=$(echo "scale=4; ${press}*1000" |bc)
